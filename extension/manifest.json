{
  "manifest_version": 3,
  "name": "MEOW",
  "version": "1.0.0",
  "description": "Monitoring & Evaluation of Online Writing :3",
  "permissions": ["activeTab", "scripting"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "128": "icons/logo-w-128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "128": "icons/logo-w-128.png"
  }
}
